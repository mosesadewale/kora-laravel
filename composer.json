{
    "name": "kora/kora-laravel",
    "description": "Laravel integration for the KoraPay PHP SDK",
    "type": "library",
    "license": "MIT",
    "keywords": ["korapay", "kora", "payments", "africa", "sdk", "laravel"],
    "require": {
        "php": "^8.2",
        "kora/kora-php": "@dev",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kora\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kora\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kora\\Laravel\\KoraServiceProvider"
            ],
            "aliases": {
                "Kora": "Kora\\Laravel\\Facades\\Kora"
            }
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../kora-php"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
